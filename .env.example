# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/diya-art

# Auth (admin JWT)
JWT_SECRET=change-me-to-a-long-random-string

# Cloudinary (image uploads)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=diya-art

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional: OpenAI for AI tagging in admin
OPENAI_API_KEY=

# Google Stitch (optional — server-side SDK / tooling; never commit real keys)
# Get a key from https://stitch.withgoogle.com/ — if exposed, rotate it immediately.
STITCH_API_KEY=
# Optional override (default is https://stitch.googleapis.com/mcp)
# STITCH_MCP_URL=
